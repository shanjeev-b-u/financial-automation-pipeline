    {
      "parameters": {
        "jsCode": "// Pulls metrics from your manual exit entries\nconst entry_price = parseFloat($json.entry_price) || 0;\nconst exit_price = parseFloat($json.exit_price) || 0;\nconst quantity = parseInt($json.quantity) || 0;\n\nconst buy_value  = entry_price * quantity;\nconst sell_value = exit_price * quantity;\nconst gross_profit = sell_value - buy_value;\n\n// Exact Indian equity intraday transaction fee structures\nconst brokerage = Math.min(20, buy_value * 0.0003) * 2; // Buy + Sell cap\nconst stt       = sell_value * 0.00025;                 // Intraday STT\nconst gst       = brokerage * 0.18;                     // 18% GST on brokerage\nconst exchange  = (buy_value + sell_value) * 0.0000345;  // NSE txn charge\nconst sebi      = (buy_value + sell_value) * 0.000001;   // SEBI turnover tax\nconst stamp     = buy_value * 0.00015;                  // Stamp duty\n\nconst total_charges = brokerage + stt + gst + exchange + sebi + stamp;\nconst net_profit = gross_profit - total_charges;\nconst return_pct = buy_value > 0 ? (Math.round((net_profit / buy_value) * 10000) / 100) : 0;\n\nreturn [{ json: {\n  ...$json,\n  buy_value: Math.round(buy_value),\n  sell_value: Math.round(sell_value),\n  gross_profit: Math.round(gross_profit * 100) / 100,\n  brokerage: Math.round(brokerage * 100) / 100,\n  stt: Math.round(stt * 100) / 100,\n  gst: Math.round(gst * 100) / 100,\n  exchange: Math.round(exchange * 100) / 100,\n  sebi: Math.round(sebi * 100) / 100,\n  stamp: Math.round(stamp * 100) / 100,\n  total_charges: Math.round(total_charges * 100) / 100,\n  net_profit: Math.round(net_profit * 100) / 100,\n  return_pct: return_pct\n}}];"
      },

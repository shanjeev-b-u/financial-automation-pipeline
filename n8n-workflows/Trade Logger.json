{
  "name": "Workflow 3 (Risk Management Gate)",
  "nodes": [
    {
      "parameters": {
        "inputSource": "passthrough"
      },
      "id": "c055762a-8fe7-4141-a639-df2372f30060",
      "typeVersion": 1.1,
      "name": "When Executed by Another Workflow",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "position": [
        272,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "// Read all incoming items from the scanner list cleanly\nconst inputItems = $input.all();\n\n// Loop through each item to calculate position size and risk rules\nreturn inputItems.map(item => {\n    const itemData = item.json;\n\n    // Extract raw values with fallbacks for both sheet formats and AI models\n    const entry = parseFloat(itemData.Price) || parseFloat(itemData.price) || 0;\n    const stockTicker = itemData.Ticker || itemData.stock || \"UNKNOWN\";\n    const aiConfidence = itemData.confidence || \"Medium\";\n\n    // Core Capital Risk Settings\n    const capital = 100000;      // Your total capital in rupees\n    const risk_pct = 0.02;       // 2% maximum risk per trade\n\n    // Financial calculations\n    const risk_amount = capital * risk_pct;\n    const stop_loss = entry * 0.97; // Stop loss set at 3% below entry\n    const risk_per_share = entry - stop_loss;\n\n    // Calculate exact whole share quantities safely\n    const quantity = risk_per_share > 0 ? Math.floor(risk_amount / risk_per_share) : 0;\n    const target = entry + (risk_per_share * 2); // 1:2 Risk-to-Reward ratio\n    const capital_needed = entry * quantity;\n\n    return {\n        json: {\n            ...itemData,\n            Ticker: stockTicker,\n            Price: entry,\n            confidence: aiConfidence,\n            quantity: quantity,\n            target: Math.round(target * 100) / 100,\n            stop_loss: Math.round(stop_loss * 100) / 100,\n            capital_needed: Math.round(capital_needed),\n            risk_amount: Math.round(risk_amount),\n            rr_ratio: 2\n        }\n    };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        352
      ],
      "id": "c43c9e7f-35bc-4d6f-85c4-c084d0dae834",
      "name": "Position Sizing Calculator"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "96a0300b-db33-495b-b977-4aba31880c19",
              "leftValue": "={{ ($json.target - $json.Price) >= (($json.Price - $json.stop_loss) * 2) }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
